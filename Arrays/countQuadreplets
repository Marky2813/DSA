// Problem: Count quadreplets
// Link: <https://codeforces.com/group/4vcXCPx8NY/contest/669913/problem/Q>
// Approach: using multiple for loops more like binary search

#include<iostream>
using namespace std; 
 
int main() {
        int len; 
        cin >> len; 
        int arr[len]; 
        int x; 
        cin >> x;
        for(int i = 0; i < len; i++) {
            cin >> arr[i];
        }
        int sum; 
        cin >> sum;
        int quadraplets = 0; 
        for(int i = 0; i < len; i++) {
            for(int j = i+1; j < len; j++) {
                for(int k = j+1; k < len; k++) {
                    for(int l = k+1; l < len; l++) {
                        if(arr[i] - 2*arr[j] + 3*arr[k] -  4*arr[l] == x) quadraplets++;
                    }  
                }
            }
        }
        cout << quadraplets;
} 